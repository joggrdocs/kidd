{
  "name": "@kidd-cli/bundler",
  "version": "0.5.0",
  "description": "Programmatic bundler for kidd CLI tools powered by Bun",
  "keywords": [
    "bun",
    "bundler",
    "cli",
    "kidd",
    "typescript"
  ],
  "homepage": "https://github.com/joggrdocs/kidd/tree/main/packages/bundler",
  "bugs": {
    "url": "https://github.com/joggrdocs/kidd/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joggrdocs/kidd.git",
    "directory": "packages/bundler"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --ignore-pattern node_modules",
    "lint:fix": "oxlint --fix --ignore-pattern node_modules",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@kidd-cli/config": "workspace:*",
    "@kidd-cli/utils": "workspace:*",
    "es-toolkit": "catalog:",
    "ts-pattern": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
