{
  "name": "@kidd-cli/cli",
  "version": "0.1.0",
  "description": "DX companion CLI for the kidd framework",
  "keywords": [
    "cli",
    "codegen",
    "kidd",
    "scaffolding"
  ],
  "license": "MIT",
  "bin": {
    "kidd": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown && mkdir -p dist/lib && cp -r src/lib/templates dist/lib/templates",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --ignore-pattern node_modules",
    "lint:fix": "oxlint --fix --ignore-pattern node_modules",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@kidd-cli/bundler": "workspace:*",
    "@kidd-cli/config": "workspace:*",
    "@kidd-cli/core": "workspace:*",
    "@kidd-cli/utils": "workspace:*",
    "fs-extra": "^11.3.3",
    "liquidjs": "catalog:",
    "picocolors": "^1.1.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
