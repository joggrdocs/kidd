{
  "name": "@kidd-cli/utils",
  "version": "0.4.0",
  "description": "Shared utilities for the kidd ecosystem",
  "keywords": [
    "cli",
    "functional",
    "kidd",
    "typescript",
    "utilities"
  ],
  "homepage": "https://github.com/joggrdocs/kidd/tree/main/packages/utils",
  "bugs": {
    "url": "https://github.com/joggrdocs/kidd/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joggrdocs/kidd.git",
    "directory": "packages/utils"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./fp": {
      "types": "./dist/fp.d.ts",
      "default": "./dist/fp.js"
    },
    "./fs": {
      "types": "./dist/fs.d.ts",
      "default": "./dist/fs.js"
    },
    "./json": {
      "types": "./dist/json.d.ts",
      "default": "./dist/json.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "default": "./dist/manifest.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "default": "./dist/validate.js"
    },
    "./tag": {
      "types": "./dist/tag.d.ts",
      "default": "./dist/tag.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24",
    "bun": ">=1.3"
  },
  "dependencies": {
    "es-toolkit": "catalog:",
    "ts-pattern": "catalog:",
    "type-fest": "^5.5.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
