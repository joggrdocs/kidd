{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "isolatedDeclarations": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "paths": {
      "@/*": ["./src/*"],
      "@test/*": ["./test/*"],
      "@kidd-cli/core": ["./src/index.ts"]
    }
  },
  "include": ["src", "test"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
