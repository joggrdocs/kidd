{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "isolatedModules": true,
    "isolatedDeclarations": true,
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "paths": {
      "@/*": ["./src/*"],
      "@test/*": ["./test/*"],
      "@kidd-cli/core": ["./src/index.ts"]
    }
  },
  "include": ["src", "test"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
