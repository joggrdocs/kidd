{
  "name": "@kidd-cli/core",
  "version": "0.5.1",
  "description": "An opinionated CLI framework for Node.js",
  "keywords": [
    "cli",
    "command",
    "framework",
    "typescript",
    "yargs",
    "zod"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joggrdocs/kidd.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./logger": {
      "types": "./dist/lib/logger.d.ts",
      "default": "./dist/lib/logger.js"
    },
    "./config": {
      "types": "./dist/lib/config.d.ts",
      "default": "./dist/lib/config.js"
    },
    "./format": {
      "types": "./dist/lib/format.d.ts",
      "default": "./dist/lib/format.js"
    },
    "./store": {
      "types": "./dist/lib/store.d.ts",
      "default": "./dist/lib/store.js"
    },
    "./project": {
      "types": "./dist/lib/project.d.ts",
      "default": "./dist/lib/project.js"
    },
    "./auth": {
      "types": "./dist/middleware/auth.d.ts",
      "default": "./dist/middleware/auth.js"
    },
    "./http": {
      "types": "./dist/middleware/http.d.ts",
      "default": "./dist/middleware/http.js"
    },
    "./icons": {
      "types": "./dist/middleware/icons.d.ts",
      "default": "./dist/middleware/icons.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --ignore-pattern node_modules",
    "lint:fix": "oxlint --fix --ignore-pattern node_modules",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@kidd-cli/config": "workspace:*",
    "@kidd-cli/utils": "workspace:*",
    "@pinojs/redact": "^0.4.0",
    "c12": "4.0.0-beta.4",
    "dotenv": "^17.3.1",
    "es-toolkit": "catalog:",
    "font-list": "^2.0.2",
    "jsonc-parser": "^3.3.1",
    "liquidjs": "catalog:",
    "picocolors": "^1.1.1",
    "ts-pattern": "catalog:",
    "yaml": "^2.8.2",
    "yargs": "^18.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/yargs": "^17.0.35",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "pino": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "pino": {
      "optional": true
    }
  }
}
